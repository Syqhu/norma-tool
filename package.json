{
  "name": "norma-tool",
  "version": "0.1.7",
  "description": "Zenless Zone Zero growth planner for Norma builds and daily planning.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --win portable",
    "pack:dir": "electron-builder --win dir"
  },
  "devDependencies": {
    "electron": "^33.4.11",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "local.norma.tool",
    "productName": "norma tool",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": "portable",
      "icon": "assets/norma-tool-icon.ico",
      "signAndEditExecutable": false
    }
  },
  "dependencies": {
    "sharp": "^0.35.2",
    "tesseract.js": "^7.0.0"
  }
}
